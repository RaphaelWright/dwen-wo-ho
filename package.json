{
  "name": "dwen-wo-ho",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "postbuild": "next-sitemap",
    "start": "next start",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "doctor": "npx react-doctor@latest",
    "fallow": "fallow",
    "fallow:audit": "fallow audit --quiet",
    "fallow:audit:all": "fallow audit --gate all --production-health --quiet",
    "fallow:baselines": "fallow dead-code --save-baseline fallow-baselines/dead-code.json || exit 0 && fallow health --save-baseline fallow-baselines/health.json && fallow dupes --save-baseline fallow-baselines/dupes.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "components:audit": "node src/lib/scripts/audit-component-conventions.mjs",
    "components:reorg": "node src/lib/scripts/reorganize-components.mjs --dry-run",
    "components:reorg:apply": "node src/lib/scripts/reorganize-components.mjs --apply",
    "hooks:audit": "node src/lib/scripts/audit-hook-conventions.mjs",
    "hooks:reorg": "node src/lib/scripts/reorganize-hooks.mjs --dry-run",
    "hooks:reorg:apply": "node src/lib/scripts/reorganize-hooks.mjs --apply",
    "constants:audit": "node src/lib/scripts/audit-constants-conventions.mjs",
    "constants:reorg": "node src/lib/scripts/reorganize-constants.mjs --dry-run",
    "constants:reorg:apply": "node src/lib/scripts/reorganize-constants.mjs --apply",
    "types:audit": "node src/lib/scripts/audit-types-conventions.mjs",
    "types:reorg": "node src/lib/scripts/reorganize-types.mjs --dry-run",
    "types:reorg:apply": "node src/lib/scripts/reorganize-types.mjs --apply",
    "utils:audit": "node src/lib/scripts/audit-utils-conventions.mjs",
    "utils:reorg": "node src/lib/scripts/reorganize-utils.mjs --dry-run",
    "utils:reorg:apply": "node src/lib/scripts/reorganize-utils.mjs --apply",
    "services:audit": "node src/lib/scripts/audit-service-conventions.mjs",
    "services:reorg": "node src/lib/scripts/reorganize-services.mjs --dry-run",
    "services:reorg:apply": "node src/lib/scripts/reorganize-services.mjs --apply",
    "conventions:audit": "pnpm components:audit && pnpm hooks:audit && pnpm constants:audit && pnpm types:audit && pnpm utils:audit && pnpm services:audit"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,json,css,md,mdx}": "prettier --write"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@hookform/devtools": "^4.4.0",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@radix-ui/react-visually-hidden": "^1.2.4",
    "@stomp/stompjs": "^7.3.0",
    "@tabler/icons-react": "^3.36.1",
    "@tanstack/react-query": "^5.83.0",
    "@types/d3-geo": "^3.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3-geo": "^3.1.1",
    "date-fns": "^4.1.0",
    "emoji-picker-react": "^4.12.0",
    "input-otp": "^1.4.2",
    "jotai": "^2.17.1",
    "lucide-react": "^0.524.0",
    "motion": "^12.34.0",
    "next": "^16.1.1",
    "next-sitemap": "^4.2.3",
    "next-themes": "^0.4.6",
    "qss": "^3.0.0",
    "radix-ui": "^1.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-easy-crop": "^5.5.6",
    "react-hook-form": "^7.61.1",
    "react-icons": "^5.5.0",
    "sharp": "^0.34.3",
    "sockjs-client": "^1.6.1",
    "sonner": "^2.0.6",
    "tailwind-merge": "^3.3.1",
    "vaul": "^1.1.2",
    "zod": "^4.0.10"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@fallow-cli/fallow-cov": "^0.4.0",
    "@hookform/resolvers": "^5.2.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/react": "^16.3.2",
    "@types/geojson": "^7946.0.16",
    "@types/node": "20.19.41",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sockjs-client": "^1.5.4",
    "eslint": "^9",
    "eslint-config-next": "15.3.4",
    "fallow": "^2.91.0",
    "happy-dom": "^20.10.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "shadcn": "^3.8.4",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.3.4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
}

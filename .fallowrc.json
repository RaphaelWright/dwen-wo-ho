{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "entry": [
    "src/app/**/page.{ts,tsx}",
    "src/app/**/layout.{ts,tsx}",
    "src/app/**/route.{ts,tsx}",
    "src/app/**/loading.{ts,tsx}",
    "src/app/**/error.{ts,tsx}"
  ],
  "ignorePatterns": [
    "**/*.d.ts",
    "src/components/ui/combobox.tsx",
    "src/components/ui/drawer.tsx",
    "src/components/ui/progress.tsx",
    "src/components/ui/sheet.tsx",
    "src/components/ui/draggable-card.tsx",
    "src/lib/scripts/**"
  ],
  "audit": {
    "deadCodeBaseline": "fallow-baselines/dead-code.json",
    "healthBaseline": "fallow-baselines/health.json",
    "dupesBaseline": "fallow-baselines/dupes.json"
  },
  "duplicates": {
    "minOccurrences": 3
  },
  "rules": {
    "unused-exports": "error",
    "boundary-violation": "error"
  },
  "boundaries": {
    "zones": [
      { "name": "routes", "patterns": ["src/app/**"] },
      { "name": "services", "patterns": ["src/services/**"] },
      { "name": "hooks", "patterns": ["src/hooks/**"] },
      { "name": "components", "patterns": ["src/components/**"] },
      { "name": "atoms", "patterns": ["src/atoms/**"] },
      { "name": "types", "patterns": ["src/lib/types/**"] },
      { "name": "utils", "patterns": ["src/lib/utils/**", "src/lib/utils.ts"] },
      { "name": "constants", "patterns": ["src/lib/constants/**"] },
      { "name": "schemas", "patterns": ["src/lib/schemas/**"] },
      { "name": "lib-core", "patterns": ["src/lib/**"] }
    ],
    "rules": [
      {
        "from": "routes",
        "allow": [
          "hooks",
          "components",
          "types",
          "utils",
          "constants",
          "schemas",
          "lib-core",
          "atoms"
        ]
      },
      {
        "from": "components",
        "allow": [
          "hooks",
          "types",
          "utils",
          "constants",
          "schemas",
          "lib-core",
          "atoms",
          "components"
        ]
      },
      {
        "from": "hooks",
        "allow": [
          "services",
          "types",
          "utils",
          "constants",
          "schemas",
          "lib-core",
          "atoms",
          "hooks"
        ],
        "allowTypeOnly": ["components"]
      },
      {
        "from": "services",
        "allow": [
          "types",
          "utils",
          "constants",
          "schemas",
          "lib-core",
          "services"
        ]
      },
      {
        "from": "atoms",
        "allow": ["types", "utils", "constants", "schemas", "lib-core", "atoms"]
      },
      {
        "from": "types",
        "allow": ["types", "constants", "schemas", "lib-core"]
      },
      {
        "from": "utils",
        "allow": ["types", "utils", "constants", "schemas", "lib-core"]
      },
      {
        "from": "constants",
        "allow": ["types", "constants", "schemas", "lib-core"]
      },
      {
        "from": "schemas",
        "allow": ["types", "constants", "schemas", "lib-core"]
      },
      {
        "from": "lib-core",
        "allow": ["types", "utils", "constants", "schemas", "lib-core"]
      }
    ],
    "coverage": {
      "allowUnmatched": ["src/**/*.test.ts", "src/**/*.test.tsx"]
    }
  },
  "ignoreDependencies": [
    "sharp",
    "eslint-config-next",
    "@fallow-cli/fallow-cov",
    "@base-ui/react",
    "vaul"
  ],
  "ignoreExports": [
    {
      "file": "src/lib/constants/components/curator/create/school-create.ts",
      "exports": ["*"]
    },
    {
      "file": "src/lib/constants/components/curator/schools/school-edit.ts",
      "exports": ["*"]
    },
    {
      "file": "src/components/ui/combobox.tsx",
      "exports": ["*"]
    },
    {
      "file": "src/components/ui/sheet.tsx",
      "exports": ["*"]
    },
    {
      "file": "src/components/ui/drawer.tsx",
      "exports": ["*"]
    },
    {
      "file": "src/components/ui/progress.tsx",
      "exports": ["*"]
    },
    {
      "file": "src/components/ui/draggable-card.tsx",
      "exports": ["*"]
    },
    {
      "file": "src/components/ui/avatar.tsx",
      "exports": ["*"]
    },
    {
      "file": "src/components/ui/dialog.tsx",
      "exports": ["*"]
    },
    {
      "file": "src/components/ui/dropdown-menu.tsx",
      "exports": ["*"]
    },
    {
      "file": "src/components/ui/input-group.tsx",
      "exports": ["*"]
    },
    {
      "file": "src/components/ui/select.tsx",
      "exports": ["*"]
    }
  ]
}
